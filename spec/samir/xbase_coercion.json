{
  "_comment": [
    "dBASE III PLUS 1.1 type-coercion table. Scope: FOUR base types C/N/D/L (Memo->C in exprs).",
    "PERIOD AUTHORITY: archive/golden-mined/HELP.DBS.strings.txt (operator/expression/type",
    "  sections @1727-1827, @1609 SET EXACT), DBASE.MSG.strings.txt (error catalog),",
    "  ASSIST.HLP.strings.txt (REPLACE @103). Corroboration: dbase-com-help/ (PLUS, lineage core),",
    "  oracles/harbour/doc/en/set.txt + subcodes.txt (Clipper lineage).",
    "III+ DELTA: NO auto-stringification. C+N, C-N, C+D, etc. = ERROR 'Data type mismatch.'.",
    "  == operator and % operator are dBASE IV, NOT III+ (gated by target_version below).",
    "OOP types (Object/Array/null/funcptr) are PLUS-era; EXCLUDED.",
    "SOURCE: ../dbase3-decomp/specs/language/coercion-table.md section 6 (verbatim basis).",
    "STATUS: III+ period-grounded; not_in_iii_plus list explicitly includes '==' (no == row here).",
    "  numfn-1..8 cells (MOD/INT/ROUND/LOG/SQRT edges) are GATED pending MINT (ADR-0008 DEC-06)."
  ],
  "status": "III+ period-grounded; items in open_questions need real DBASE.EXE under DOSBox",
  "schema_version": 1,
  "target_version": "dBASE III PLUS 1.1",
  "types": ["C", "N", "D", "L"],
  "error_messages": {
    "mismatch": "Data type mismatch.",
    "num_overflow": "Numeric overflow (data was lost).",
    "not_numeric": "Not a numeric expression.",
    "not_logical": "Not a Logical expression.",
    "not_character": "Not a Character expression."
  },
  "modes": {
    "SET_EXACT": { "values": ["OFF","ON"], "default": "OFF",
                   "affects": ["=","<>","#","SEEK","FIND"],
                   "note": "$ ignores this; ordering <,>,<=,>= ignore this; == is IV-only" },
    "SET_DECIMALS": { "default": 2, "note": "display/derived decimals; not stored value" },
    "collation": { "value": "CP437", "note": "byte-wise ASCII order, US language driver" }
  },
  "not_in_iii_plus": ["==", "!=", "%", "DTOS", "auto_stringify_C_plus_N"],
  "rules": {
    "R_same_type":       "Operands of one operator must share a type; only D/N arithmetic is mixed-type.",
    "R_begins_with":     "C = C, EXACT OFF: LEFT must begin with RIGHT; directional; right-trailing-blanks ignored; '' on right matches all.",
    "R_exact_blankpad":  "C = C, EXACT ON: equal except trailing blanks (either side) ignored; case-sensitive.",
    "R_date_plus_num":   "D +/- N -> D (shift days); blank date stays blank.",
    "R_date_minus_date": "D - D -> N (#days); any subtraction touching a blank date = 0.",
    "R_concat_plus":     "C + C -> C; trailing blanks kept in place.",
    "R_concat_minus":    "C - C -> C; LHS trailing blanks moved to end; total length preserved.",
    "R_substr":          "c1 $ c2 -> L; literal substring; case-sensitive; blanks significant; unaffected by SET EXACT.",
    "R_order_same_type": "<,>,<=,>= require SAME base type; cross-type -> mismatch.",
    "R_blankdate_high":  "In ordering, a blank date is GREATER THAN any non-blank date.",
    "R_no_truthiness":   ".AND./.OR./.NOT. and IF/DO WHILE/FOR/WHILE guards require L; non-L -> 'Not a Logical expression.'"
  },
  "operator_coercion": [
    { "lhs":"N","op":"+","rhs":"N","result":"N" },
    { "lhs":"C","op":"+","rhs":"C","result":"C","rule":"R_concat_plus" },
    { "lhs":"D","op":"+","rhs":"N","result":"D","rule":"R_date_plus_num" },
    { "lhs":"N","op":"+","rhs":"D","result":"D","rule":"R_date_plus_num" },
    { "lhs":"C","op":"+","rhs":"N","result":"error","error":"mismatch","note":"III+: NOT stringified" },
    { "lhs":"N","op":"+","rhs":"C","result":"error","error":"mismatch" },
    { "lhs":"C","op":"+","rhs":"D","result":"error","error":"mismatch" },
    { "lhs":"D","op":"+","rhs":"D","result":"error","error":"mismatch" },
    { "lhs":"N","op":"-","rhs":"N","result":"N" },
    { "lhs":"D","op":"-","rhs":"N","result":"D","rule":"R_date_plus_num" },
    { "lhs":"D","op":"-","rhs":"D","result":"N","rule":"R_date_minus_date" },
    { "lhs":"C","op":"-","rhs":"C","result":"C","rule":"R_concat_minus" },
    { "lhs":"C","op":"-","rhs":"N","result":"error","error":"mismatch" },
    { "lhs":"N","op":"-","rhs":"D","result":"error","error":"mismatch","note":"only D-N sanctioned" },
    { "lhs":"N","op":"*","rhs":"N","result":"N" },
    { "lhs":"N","op":"/","rhs":"N","result":"N","note":"div-by-zero -> numeric error (oracle-resolves)" },
    { "lhs":"N","op":"**","rhs":"N","result":"N" },
    { "lhs":"N","op":"^","rhs":"N","result":"N" },
    { "lhs":"C","op":"=","rhs":"C","result":"L","exact_off":"R_begins_with","exact_on":"R_exact_blankpad" },
    { "lhs":"N","op":"=","rhs":"N","result":"L" },
    { "lhs":"D","op":"=","rhs":"D","result":"L" },
    { "lhs":"L","op":"=","rhs":"L","result":"L" },
    { "lhs":"C","op":"<>","rhs":"C","result":"L","note":"negation of =; follows SET EXACT" },
    { "lhs":"C","op":"#","rhs":"C","result":"L","note":"alias of <>" },
    { "lhs":"N","op":"<","rhs":"N","result":"L" },
    { "lhs":"C","op":"<","rhs":"C","result":"L","note":"CP437 byte order" },
    { "lhs":"D","op":"<","rhs":"D","result":"L","rule":"R_blankdate_high" },
    { "lhs":"L","op":"<","rhs":"L","result":"L","note":".F. < .T." },
    { "lhs":"N","op":"<","rhs":"C","result":"error","error":"mismatch","rule":"R_order_same_type" },
    { "lhs":"C","op":"$","rhs":"C","result":"L","rule":"R_substr" },
    { "lhs":"N","op":"$","rhs":"C","result":"error","error":"mismatch","note":"$ is C-only" },
    { "lhs":"L","op":".AND.","rhs":"L","result":"L" },
    { "lhs":"L","op":".OR.","rhs":"L","result":"L" },
    { "lhs":"N","op":".AND.","rhs":"L","result":"error","error":"not_logical","rule":"R_no_truthiness" }
  ],
  "assignment_coercion": [
    { "target":"C","expr":"C","result":"ok","on_too_long":"truncate","on_short":"pad_blanks" },
    { "target":"C","expr":"N","result":"error","error":"mismatch","note":"use STR()" },
    { "target":"C","expr":"D","result":"error","error":"mismatch","note":"use DTOC()" },
    { "target":"C","expr":"L","result":"error","error":"mismatch" },
    { "target":"N","expr":"N","result":"ok","on_overflow":"stars_fill","error_on_overflow":"num_overflow","on_excess_decimals":"round" },
    { "target":"N","expr":"C","result":"error","error":"mismatch","note":"use VAL()" },
    { "target":"N","expr":"D","result":"error","error":"mismatch" },
    { "target":"D","expr":"D","result":"ok","blank":"8 spaces" },
    { "target":"D","expr":"C","result":"error","error":"mismatch","note":"use CTOD()" },
    { "target":"L","expr":"L","result":"ok" },
    { "target":"M","expr":"C","result":"ok","note":"memo stores text" }
  ]
}
